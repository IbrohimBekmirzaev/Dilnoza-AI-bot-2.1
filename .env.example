# Dilnoza AI Telegram Bot uchun muhit o'zgaruvchilari namunasi
# Bu faylni .env nomi bilan ko'chirib, mahalliy ishga tushirish uchun to'ldiring.

# @BotFather bergan Telegram bot tokeni
BOT_TOKEN=telegram_bot_tokeningiz

# Dilnoza AI API kaliti
# Kalit Dilnoza AI xizmatiga mos bo'lishi kerak.
DILNOZA_AI_API_KEY=sizning_dilnoza_ai_kalitingiz

# Dilnoza AI model nomi
DILNOZA_AI_MODEL=dilnoza-2.1

# Admin log guruhi chat ID si (superguruhlar uchun -100 bilan boshlanadi)
LOG_GROUP_ID=-1001234567890

# Bot javob berishidan oldin yuborilishi shart bo'lgan aktivatsiya iborasi
ACTIVATION_PHRASE=Dilnoza 2.1 men Ibrohim 1.0 man ishga tush

# Botni to'xtatish uchun yuboriladigan ibora
DEACTIVATION_PHRASE=Dilnoza ishdan toxta

# Telegram superguruh mavzu (thread) ID lari
# Ularni guruhdagi har bir mavzuda /topicid yuborib olishingiz mumkin
START_THREAD_ID=1491
STOP_THREAD_ID=1491
SUPPORT_THREAD_ID=3
ERROR_THREAD_ID=4

# Veb server porti (Railway buni odatda avtomatik beradi, standart qiymat 3000)
PORT=0
